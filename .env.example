# =============================================================
# RAG Learning System — Cấu hình môi trường
# Sao chép file này thành .env và điền các giá trị phù hợp.
# Tất cả biến RAG_* được load tự động bởi pydantic-settings.
# =============================================================

# ----- Thư mục dữ liệu ----------------------------------------
RAG_DATA_DIR=data
RAG_STORAGE_DIR=storage/qdrant
RAG_QDRANT_COLLECTION=rag_chunks

# ----- Chunking -----------------------------------------------
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5

# ----- Embedding model ----------------------------------------
# Mô hình embedding tiếng Việt mặc định (HuggingFace Hub)
RAG_EMBEDDING_MODEL=GreenNode/GreenNode-Embedding-Large-VN-Mixed-V1

# ----- LLM Provider -------------------------------------------
# Chọn một trong: hf_local | gemini | vllm
RAG_LLM_PROVIDER=gemini
RAG_LLM_TEMPERATURE=0.1

# ----- HuggingFace Local (RAG_LLM_PROVIDER=hf_local) ----------
RAG_HF_MODEL=/mnt/pretrained_fm/Qwen_Qwen3-4B-Instruct-2507
RAG_HF_DEVICE=0          # -1 = CPU, 0/1/... = GPU index
RAG_HF_MAX_NEW_TOKENS=2048

# ----- Gemini (RAG_LLM_PROVIDER=gemini) -----------------------
RAG_GEMINI_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=your-google-api-key-here   # Bắt buộc khi dùng gemini

# ----- vLLM (RAG_LLM_PROVIDER=vllm) --------------------------
RAG_VLLM_API_BASE=http://localhost:8001/v1
RAG_VLLM_API_KEY=EMPTY

# ----- Tóm tắt & Sinh nội dung --------------------------------
RAG_SUMMARIZE_BATCH_SIZE=10
RAG_SUMMARIZE_RETRIEVAL_K=12
RAG_GENERATION_RETRIEVAL_K=16

# ----- Mặc định Quiz & Flashcards ----------------------------
RAG_QUIZ_DEFAULT_COUNT=8
RAG_FLASHCARDS_DEFAULT_COUNT=15

# ----- URL của API server (dùng trong Streamlit UI) -----------
RAG_API_URL=http://localhost:8000
